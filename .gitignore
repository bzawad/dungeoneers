# Godot 4+ (https://github.com/github/gitignore/blob/main/Godot.gitignore)
.godot/
.import/
.nomedia

# Machine-specific / local-only (do not commit real credentials)
override.cfg
export.cfg
export_credentials.cfg
export_presets.cfg

*.translation

.mono/
data_*/
mono_crash.*.json

*.tmp

# Android export build directory (next to project.godot)
/android/

# Project-specific CI / check logs
.godot_checks.log
.godot_run_generation.log
godot_check.log

# ---- OS ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ---- IDE ----
.vscode/
.idea/
*.sublime-*

# ---- Logs & backups ----
*.log
*~
*.bak
*.backup
*.old
*.orig

# ---- Temp filenames ----
*.temp
*.temporary

# ---- Exported builds (commit sources; not binaries) ----
builds/
exports/
*.exe
*.pck
*.apk
*.aab
*.ipa
*.dmg

# ---- Python (tools under tools/) ----
__pycache__/
*.py[cod]
*$py.class

# ---- Node (if any JS tooling) ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Local env ----
.env
.env.local
.env.*.local

# Loose compressed import artifacts (normally under .godot/)
*.ctex
